root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
# Unused code and values
# IDE0051: remove unused private members
# IDE0052: remove unread private fields
# IDE0059: remove unnecessary assignments
# IDE0060: remove unused parameters
# CS0168: variable declared but never used
# CS0219: variable assigned but never used

dotnet_diagnostic.IDE0051.severity = warning
dotnet_diagnostic.IDE0052.severity = warning
dotnet_diagnostic.IDE0059.severity = warning
dotnet_diagnostic.IDE0060.severity = warning
dotnet_diagnostic.CS0168.severity = warning
dotnet_diagnostic.CS0219.severity = warning

# Async/await usage
# CS1998: async method has no await
# CS4014: unobserved task call that is not awaited

dotnet_diagnostic.CS1998.severity = warning
dotnet_diagnostic.CS4014.severity = warning

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
