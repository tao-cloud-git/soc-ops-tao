@using SocOps.Models

<div class="screen-shell">
    <div class="hero-stack">
        <section class="app-frame glass-card">
            <header class="app-header">
                <button
                    @onclick="OnReset"
                    class="ghost-button app-back-button">
                    ← Back
                </button>

                <div class="header-stack">
                    <p class="eyebrow">Metallic Chrome Board</p>
                    <h1 class="header-title">Soc Ops</h1>
                </div>

                <div class="app-back-spacer" aria-hidden="true"></div>
            </header>

            <p class="instruction-strip">
                Tap a square when you find someone who matches it.
            </p>

            @if (HasBingo)
            {
                <div class="bingo-banner">
                    BINGO! You got a line.
                </div>
            }

            <div class="board-shell">
                <BingoBoard
                    Board="@Board"
                    WinningSquareIds="@WinningSquareIds"
                    OnSquareClick="@OnSquareClick" />
            </div>
        </section>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
