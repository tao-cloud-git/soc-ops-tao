<div class="modal-overlay z-50">
    <div class="modal-shell">
        <div class="modal-icon mx-auto">🎉</div>
        <h2 class="modal-title">BINGO!</h2>
        <p class="modal-copy">You completed a line.</p>

        <button
            @onclick="OnDismiss"
            class="chrome-button transition-all">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
