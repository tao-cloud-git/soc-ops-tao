<div class="screen-shell">
    <div class="hero-stack text-center">
        <div class="hero-badge mx-auto">Corporate Clean Blue</div>

        <section class="hero-panel metallic-card mb-8">
            <div class="status-pill mb-4">Gradient Glass Interface</div>
            <h1 class="hero-title text-gray-900 text-balance">Soc Ops</h1>
            <p class="text-lg text-gray-600 mb-4">Social Bingo</p>
            <p class="hero-subtitle text-balance">
                Uma interface mais executiva, nítida e tátil para rodadas rápidas de networking.
            </p>

            <div class="glass-card text-left mb-8">
                <h2 class="section-title">How to play</h2>
                <ul class="instruction-list text-sm">
                    <li>Find people who match the questions.</li>
                    <li>Tap a square when you find a match.</li>
                    <li>Get 5 in a row to win.</li>
                </ul>
            </div>

            <button
                @onclick="OnStart"
                class="chrome-button transition-all">
                Start Game
            </button>
        </section>

        <p class="surface-note mx-auto max-w-sm text-balance">
            Visual language preserva o fluxo atual e prepara o restante do tabuleiro para glass panels, chrome highlights e estados de jogo mais claros.
        </p>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
